# Authentication
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters. Never commit the real value to git.
JWT_SECRET=YOUR_GENERATED_SECRET_HERE

# Database (Postgres, e.g. Neon via Vercel Marketplace)
# Get this from Vercel: Project -> Storage -> your Postgres DB -> .env.local tab
# Or run: vercel env pull .env.local
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Environment (development or production)
NODE_ENV=development

# Session Configuration (in hours and minutes)
SESSION_MAX_HOURS=8
SESSION_INACTIVITY_MINUTES=30

# Cookie Settings
COOKIE_NAME=admin_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
